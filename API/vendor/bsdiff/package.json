{
  "name": "@hot-updater/bsdiff",
  "version": "0.32.0-petsee-bsdiff40.1",
  "description": "FORK of @hot-updater/bsdiff: emits classic BSDIFF40 (3 separate bzip2 streams) instead of ENDSLEY/BSDIFF43, for compatibility with expo-updates on-device bspatch.c. See API/vendor/bsdiff/README.md.",
  "license": "MIT AND BSD-2-Clause AND bzip2-1.0.6",
  "type": "module",
  "main": "./dist/node.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workerd": "./dist/worker.js",
      "worker": "./dist/worker.js",
      "deno": "./dist/deno.js",
      "bun": "./dist/bun.js",
      "node": "./dist/node.js",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./deno": {
      "types": "./dist/deno.d.ts",
      "import": "./dist/deno.js",
      "default": "./dist/deno.js"
    },
    "./bun": {
      "types": "./dist/bun.d.ts",
      "import": "./dist/bun.js",
      "default": "./dist/bun.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "default": "./dist/worker.js"
    }
  },
  "files": [
    "NOTICE.md",
    "dist",
    "assets",
    "scripts/wasm-build",
    "rust/hdiff-wasm/Cargo.toml",
    "rust/hdiff-wasm/src"
  ],
  "keywords": [
    "hermes",
    "hbc",
    "bsdiff",
    "bspatch",
    "react-native"
  ],
  "repository": "https://github.com/gronxb/hot-updater",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsdown": "0.21.6",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "node ./scripts/wasm-build/build-wasm.mjs && tsdown",
    "build:watch": "tsdown --watch",
    "build:wasm": "node ./scripts/wasm-build/build-wasm.mjs"
  }
}